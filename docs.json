{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "G4 OS",
  "colors": {
    "primary": "#B9915B",
    "light": "#B9915B",
    "dark": "#D1BEA4"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentação",
        "groups": [
          {
            "group": "Começando",
            "pages": [
              "index",
              "getting-started/quickstart",
              "getting-started/create-workspace"
            ]
          },
          {
            "group": "Plataforma",
            "pages": [
              "product/workspaces",
              "product/sessions",
              "product/agents",
              "product/voice-input"
            ]
          },
          {
            "group": "Conexões",
            "pages": [
              "product/connections/index",
              "product/connections/managed-connections",
              "product/connections/managed-agents"
            ]
          },
          {
            "group": "Operação",
            "pages": [
              "product/integrations",
              "product/automation",
              "product/security",
              "product/privacy-and-data"
            ]
          },
          {
            "group": "Suporte no App",
            "pages": [
              "support/index",
              "support/app-settings",
              "support/ai",
              "support/agents",
              "support/sources",
              "support/skills",
              "support/automation",
              "support/permissions",
              "support/tags",
              "support/appearance",
              "support/workspace",
              "support/cloud-sync",
              "support/repair-mode",
              "support/usage",
              "support/preferences",
              "support/sharing",
              "support/collaborative-session",
              "support/remote-control",
              "support/marketplace"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Introdução",
          "href": "/",
          "icon": "house"
        },
        {
          "anchor": "Quickstart",
          "href": "/getting-started/quickstart",
          "icon": "rocket"
        },
        {
          "anchor": "Suporte",
          "href": "/support",
          "icon": "headset"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Quickstart",
        "href": "/getting-started/quickstart"
      },
      {
        "label": "Suporte",
        "href": "/support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Acessar G4 OS",
      "href": "https://g4oscloud.com/download-public"
    }
  },
  "redirects": [
    {
      "source": "/product/connection-types",
      "destination": "/product/connections"
    },
    {
      "source": "/quickstart",
      "destination": "/getting-started/quickstart"
    },
    {
      "source": "/development",
      "destination": "/getting-started/quickstart"
    },
    {
      "source": "/essentials/settings",
      "destination": "/support/app-settings"
    },
    {
      "source": "/essentials/navigation",
      "destination": "/support"
    },
    {
      "source": "/essentials/:slug*",
      "destination": "/support"
    },
    {
      "source": "/ai-tools/:slug*",
      "destination": "/support/ai"
    },
    {
      "source": "/api-reference/introduction",
      "destination": "/support"
    }
  ],
  "footer": {
    "socials": {
      "github": "https://github.com/Gestao-Quatro-Ponto-Zero"
    }
  }
}
